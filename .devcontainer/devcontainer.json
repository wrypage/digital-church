{
  "name": "Python Standard",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "if [ -f requirements.txt ]; then pip install -r requirements.txt; fi"
}